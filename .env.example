# ──────────────── Django ────────────────
DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_TIME_ZONE=UTC

# Default superuser created on first boot
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=ChangeMe!2026
DJANGO_SUPERUSER_EMAIL=admin@mfp.local

# ──────────────── Database ────────────────
# SQLite by default (file-based, persistent volume).
# For Postgres, set DATABASE_URL=postgres://user:pass@db:5432/mfp
DATABASE_URL=sqlite:////app/data/db.sqlite3

# ──────────────── Celery / Redis ────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────── Storage ────────────────
MEDIA_ROOT=/app/data/media
EVIDENCE_ROOT=/app/data/evidence
REPORT_ROOT=/app/data/reports

# ──────────────── Volatility ────────────────
VOLATILITY_BIN=vol
VOLATILITY_TIMEOUT=1800
VOLATILITY_PLUGINS=windows.pslist,windows.pstree,windows.netscan,windows.cmdline,windows.dlllist,windows.handles,windows.malfind,windows.filescan,windows.hashdump,windows.sessions,windows.svcscan

# ──────────────── Security ────────────────
JWT_ACCESS_LIFETIME_MIN=30
JWT_REFRESH_LIFETIME_DAYS=7
RATE_LIMIT_ANON=30/min
RATE_LIMIT_USER=120/min
MAX_UPLOAD_SIZE_MB=8192

# ──────────────── AI Engine (optional) ────────────────
AI_ENABLED=0
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
